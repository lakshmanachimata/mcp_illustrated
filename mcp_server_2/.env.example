# MCP Server 2 — copy to .env and set as needed
# Port (default 8002)
# MCP_PORT=8002

# Bright Data proxy for scraping at scale (optional)
# BRIGHT_DATA_PROXY=http://user:pass@brd.superproxy.io:22225

# Zvec: base directory for vector collections (no separate server)
# ZVEC_BASE_PATH=./zvec_data

# Embedding model (sentence-transformers)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
